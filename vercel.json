{
  "buildCommand": "npx prisma generate && node scripts/prod-setup.mjs && npm run build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/snapshots",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/reports",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/alerts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/clickr-reset",
      "schedule": "5 0 1 * *"
    }
  ]
}
