# ─── Database (Vercel Postgres / Neon) ──────────────────────────────
# Pull these from Vercel after attaching a Postgres database:
#   npm run vercel:env:pull
#
# DATABASE_URL must be the *pooled* connection string (POSTGRES_PRISMA_URL).
# DIRECT_URL must be the *non-pooled* connection (POSTGRES_URL_NON_POOLING) and is
# used by Prisma migrations / introspection only.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Used to sign session cookies — generate a long random string
SESSION_SECRET="change-me-to-a-long-random-string"
# Legacy plain-password login (used if Google OAuth is not configured)
APP_PASSWORD="change-me"
# Secret for cron job authentication (Bearer token on /api/cron/* routes)
CRON_SECRET="change-me-to-a-long-random-string"

# ─── Google OAuth (for staff login) ──────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Vercel Blob (for screenshot uploads) ────────────────────────────────────
# Created automatically when you add Vercel Blob storage to your project.
# Run: vercel env pull .env.local  after linking the project.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for AI insights, report commentary, and chat features.
# Can also be stored in the DB (AppSetting key: openaiApiKey) via the Settings UI.
OPENAI_API_KEY="sk-..."

# ─── SemRush ─────────────────────────────────────────────────────────────────
# https://www.semrush.com/api-analytics/
SEMRUSH_API_KEY="your-semrush-api-key"

# ─── Moz (Domain Authority) ──────────────────────────────────────────────────
# https://moz.com/products/api
MOZ_ACCESS_ID="your-moz-access-id"
MOZ_SECRET_KEY="your-moz-secret-key"

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# Service account — see README for full setup steps
# JSON key file fields: client_email + private_key
GA4_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
GA4_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ─── Google Search Console & YouTube ─────────────────────────────────────────
# Generic Google API key (server-side, no OAuth scope needed for CrUX / YouTube)
GOOGLE_API_KEY="your-google-api-key"
# Chrome UX Report (Core Web Vitals) API key — may be same as GOOGLE_API_KEY
GOOGLE_CRUX_API_KEY="your-crux-api-key"

# ─── Google Ads ──────────────────────────────────────────────────────────────
# https://developers.google.com/google-ads/api/docs/get-started/oauth-cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN="your-developer-token"
GOOGLE_ADS_CLIENT_ID="your-oauth-client-id"
GOOGLE_ADS_CLIENT_SECRET="your-oauth-client-secret"
GOOGLE_ADS_REFRESH_TOKEN="your-refresh-token"
# MCC (manager account) customer ID — digits only, no dashes
GOOGLE_ADS_MANAGER_CUSTOMER_ID="1234567890"

# ─── Meta Ads ────────────────────────────────────────────────────────────────
# Long-lived user access token (~60 days). Generate via:
#   node scripts/get-meta-long-lived-token.mjs <short_lived_token>
META_ACCESS_TOKEN="your-meta-access-token"

# ─── TikTok Ads ──────────────────────────────────────────────────────────────
# https://business-api.tiktok.com/portal/docs
TIKTOK_ACCESS_TOKEN="your-tiktok-access-token"

# ─── Microsoft Ads (Bing) ────────────────────────────────────────────────────
# https://learn.microsoft.com/en-us/advertising/guides/authentication-oauth
MICROSOFT_ADS_DEVELOPER_TOKEN="your-developer-token"
MICROSOFT_ADS_CLIENT_ID="your-client-id"
MICROSOFT_ADS_CLIENT_SECRET="your-client-secret"
MICROSOFT_ADS_REFRESH_TOKEN="your-refresh-token"
MICROSOFT_ADS_CUSTOMER_ID="your-customer-id"

# ─── Microsoft 365 (email notifications) ─────────────────────────────────────
# App registration in Azure AD with Mail.Send permission
MS365_CLIENT_ID="your-azure-app-client-id"
MS365_CLIENT_SECRET="your-azure-app-client-secret"
MS365_TENANT_ID="your-azure-tenant-id"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Landing Pages public domain ──────────────────────────────────────────────
# Wildcard subdomain root used to serve published landing pages at
# https://{client-slug}.{LP_DOMAIN}/{lp-slug}. The apex redirects to
# NEXT_PUBLIC_APP_URL. Configure DNS:
#   *.clickr.marketing  CNAME  cname.vercel-dns.com
#   clickr.marketing    A      76.76.21.21
# and add both *.clickr.marketing + clickr.marketing as Vercel domains.
LP_DOMAIN="clickr.marketing"
NEXT_PUBLIC_LP_DOMAIN="clickr.marketing"
