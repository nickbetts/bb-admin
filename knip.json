{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "next.config.ts",
    "playwright.config.ts",
    "prisma.config.ts",
    "vitest.config.ts",
    "src/app/**/*.{ts,tsx}",
    "src/instrumentation.ts",
    "src/proxy.ts",
    "prisma/seed.ts",
    "scripts/**/*.{ts,mjs}",
    "tests/**/*.ts"
  ],
  "project": ["src/**/*.{ts,tsx}", "prisma/**/*.ts", "scripts/**/*.{ts,mjs}", "tests/**/*.ts"],
  "ignoreDependencies": ["@libsql/client"],
  "ignoreBinaries": ["vercel"]
}
