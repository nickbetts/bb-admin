generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  name                 String?
  password             String
  role                 String               @default("user")
  mustChangePassword   Boolean              @default(false)
  roleId               String?
  notificationPrefs    String?
  canManageTracking    Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  timeEntries          AgencyTimeEntry[]
  conversations        ClientConversation[]
  uploadedClientFiles  ClientFile[]
  landingPages         LandingPage[]
  notifications        Notification[]
  createdReports       Report[]             @relation("ReportCreatedBy")
  createdSalesHandoffs SalesHandoff[]       @relation("SalesHandoffCreatedBy")
  ownedSalesHandoffs   SalesHandoff[]       @relation("SalesHandoffOwner")
  salesHandoffEvents   SalesHandoffEvent[]  @relation("SalesHandoffEventActor")
  sessions             Session[]
  taskAssignments      TaskAssignee[]
  taskAttachments      TaskAttachment[]
  taskComments         TaskComment[]
  taskTimeLogs         TaskTimeLog[]
  trackingAudits       TrackingAudit[]      @relation("TrackingAuditAuditedBy")
  userRole             Role?                @relation(fields: [roleId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Client {
  id                        String                      @id @default(cuid())
  name                      String
  slug                      String                      @unique
  website                   String?
  logoUrl                   String?
  ga4PropertyId             String?
  ga4PropertyName           String?
  semrushDomain             String?
  semrushProjectId          Int?
  semrushCampaignIds        String?
  metaAccountId             String?
  metaAccountName           String?
  metaAccessToken           String?
  gaCredentials             String?
  googleAdsCustomerId       String?
  googleAdsAccountName      String?
  searchConsoleSiteUrl      String?
  aiReportInstructions      String?
  woocommerceUrl            String?
  woocommerceKey            String?
  woocommerceSecret         String?
  shopifyStoreDomain        String?
  shopifyAccessToken        String?
  contractedHours           String?
  tiktokAdvertiserId        String?
  tiktokAccessToken         String?
  microsoftAdsAccountId     String?
  microsoftAdsAccountName   String?
  cwvUrl                    String?
  reportSchedule            String?
  notifyEmail               String?
  linkedinAccountId         String?
  linkedinAccountName       String?
  linkedinAccessToken       String?
  klaviyoApiKey             String?
  klaviyoAccountName        String?
  hubspotPortalId           String?
  hubspotAccessToken        String?
  youtubeChannelId          String?
  youtubeChannelName        String?
  callrailAccountId         String?
  callrailApiKey            String?
  competitorDomains         String?
  clickFraudToken           String?                     @unique
  contactEmails             String?
  contentStrategyLimits     String?
  defaultAnalyticsConfig    String                      @default("{}")
  signalConfig              String?
  status                    String                      @default("active")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  country                   String?
  stripeDefaultCurrency     String?
  stripePublishableKey      String?
  stripeSecretKeyEnc        String?
  stripeWebhookSecretEnc    String?
  actions                   ActionItem[]
  timeEntries               AgencyTimeEntry[]
  budgetRecommendations     BudgetRecommendation[]
  clickFraudEvents          ClickFraudEvent[]
  communications            ClientCommunication[]
  conversations             ClientConversation[]
  files                     ClientFile[]
  goals                     ClientGoal[]
  invoices                  ClientInvoice[]
  portalUsers               ClientPortalUser[]
  retainers                 ClientRetainer[]
  taskCategories            ClientTaskCategory[]
  competitorSnapshots       CompetitorSnapshot[]
  contentGenerators         ContentGenerator[]
  contentStrategies         ContentStrategy[]
  detectedAnomalies         DetectedAnomaly[]
  emailVerificationJobs     EmailVerificationJob[]
  grandPlans                GrandPlan[]
  internalLinkingPlans      InternalLinkingPlan[]
  keywordResearch           KeywordPlannerResearch[]
  landingPages              LandingPage[]
  LandingPagePaymentSession LandingPagePaymentSession[]
  llmGenerations            LlmGeneration[]
  mediaPlans                MediaPlan[]
  snapshots                 MetricSnapshot[]
  notifications             Notification[]
  portalThreads             PortalThread[]
  proposals                 Proposal[]
  qaChecklists              QaChecklist[]
  reports                   Report[]
  salesHandoffs             SalesHandoff[]
  strategyDocuments         StrategyDocument[]
  trackingSetups            TrackingSetup[]
  trackingAudits            TrackingAudit[]             @relation("TrackingAuditClient")
}

model ClientGoal {
  id           String   @id @default(cuid())
  clientId     String
  title        String
  description  String?
  metric       String
  channel      String?
  targetValue  Float
  currentValue Float?
  unit         String?
  targetDate   String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model StrategyDocument {
  id         String   @id @default(cuid())
  clientId   String
  title      String
  period     String
  content    String
  type       String   @default("strategy")
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BudgetRecommendation {
  id              String   @id @default(cuid())
  clientId        String
  periodStart     String
  periodEnd       String
  recommendations String
  summary         String?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Report {
  id                String          @id @default(cuid())
  clientId          String
  title             String
  period            String
  status            String          @default("draft")
  shareToken        String?         @unique
  customStartDate   String?
  customEndDate     String?
  compareStartDate  String?
  compareEndDate    String?
  narrativeData     String?
  approvalStatus    String?
  approvalNotes     String?
  approvedBy        String?
  approvedAt        DateTime?
  portalPublishedAt DateTime?
  portalPublishedBy String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdByUserId   String?
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy         User?           @relation("ReportCreatedBy", fields: [createdByUserId], references: [id])
  comments          ReportComment[]
  sections          ReportSection[]
  screenshots       Screenshot[]
}

model ReportSection {
  id          String   @id @default(cuid())
  reportId    String
  sectionType String
  title       String
  commentary  String?
  contentText String?
  orderIndex  Int      @default(0)
  enabled     Boolean  @default(true)
  cardConfig  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id         String   @id @default(cuid())
  reportId   String
  sectionId  String?
  filename   String
  url        String
  caption    String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  sections    String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoogleConnection {
  id           String   @id @default(cuid())
  label        String
  email        String
  refreshToken String
  createdAt    DateTime @default(now())
}

model MetricSnapshot {
  id           String   @id @default(cuid())
  clientId     String
  sectionType  String
  periodStart  String
  periodEnd    String
  metrics      String
  campaignData String?
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sectionType, periodStart, periodEnd])
}

model ServerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  source    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
}

model CronLog {
  id               String    @id @default(cuid())
  jobName          String
  triggeredBy      String    @default("cron")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  status           String    @default("running")
  clientsTotal     Int       @default(0)
  snapshotsNew     Int       @default(0)
  snapshotsSkipped Int       @default(0)
  errors           Int       @default(0)
  details          String?
}

model ApiCache {
  key       String   @id
  data      String
  fetchedAt DateTime @default(now())
  expiresAt DateTime
}

model KeywordPlannerResearch {
  id               String      @id @default(cuid())
  userId           String
  clientId         String?
  title            String
  website          String
  brief            String
  location         String      @default("2826")
  adGroups         String
  selectedKws      String
  ideas            String
  maxCpc           String      @default("")
  monthlyBudget    String      @default("")
  conversionRate   String      @default("3")
  websiteContext   String?
  proposedServices String      @default("[]")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  grandPlans       GrandPlan[]
  client           Client?     @relation(fields: [clientId], references: [id])
  proposals        Proposal[]
}

model Proposal {
  id               String                  @id @default(cuid())
  userId           String
  clientId         String?
  clientName       String
  website          String                  @default("")
  title            String
  html             String
  servicesJson     String                  @default("[]")
  timelineJson     String                  @default("[]")
  proposalDataJson String?
  shareToken       String?                 @unique
  viewCount        Int                     @default(0)
  lastViewedAt     DateTime?
  researchId       String?
  pipelineStage    String                  @default("prospect")
  pipelineNotes    String?
  expectedValue    Float?
  closeDate        String?
  lostReason       String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  grandPlans       GrandPlan[]
  client           Client?                 @relation(fields: [clientId], references: [id])
  research         KeywordPlannerResearch? @relation(fields: [researchId], references: [id])
  enquiries        ProposalEnquiry[]
  salesHandoffs    SalesHandoff[]
}

model ProposalEnquiry {
  id         String   @id @default(cuid())
  proposalId String
  name       String
  email      String
  phone      String?
  message    String
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model QaChecklist {
  id              String   @id @default(cuid())
  clientId        String
  checklistType   String   @default("website")
  label           String?
  websiteUrl      String?
  status          String   @default("in_progress")
  marketingChecks String   @default("{}")
  devChecks       String   @default("{}")
  notes           String?
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model LlmTemplate {
  id             String   @id @default(cuid())
  name           String
  sector         String
  description    String?
  templateText   String
  promptGuidance String?
  isBuiltIn      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ownerEmail     String?
  ownerUserId    String?

  @@index([ownerUserId])
}

model LlmGeneration {
  id                    String    @id @default(cuid())
  clientId              String?
  userId                String
  createdByEmail        String?
  title                 String
  website               String
  templateId            String?
  templateName          String
  sector                String
  output                String
  pagesCrawled          Int       @default(0)
  deadUrlsRemoved       Int       @default(0)
  usedWebSearchFallback Boolean   @default(false)
  authorityDataUsed     Boolean   @default(false)
  socialProfilesFound   Int       @default(0)
  generationMs          Int?
  shareToken            String?   @unique
  sharePassword         String?
  shareExpiresAt        DateTime?
  viewCount             Int       @default(0)
  lastViewedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  client                Client?   @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  clientId    String?
  type        String
  severity    String?
  title       String
  body        String
  metadata    String?
  channel     String    @default("in_app")
  status      String    @default("unread")
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientConversation {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id                   String           @id @default(cuid())
  clientId             String
  categoryId           String?
  title                String
  description          String?
  status               String           @default("to_do")
  priority             String           @default("medium")
  boardOrder           Int              @default(0)
  assignedTo           String?
  dueDate              String?
  completedAt          DateTime?
  outcome              String?
  sourceType           String?
  sourceRef            String?
  forApprovalAt        DateTime?
  internalApprovedBy   String?
  internalApprovedAt   DateTime?
  clientApprovedBy     String?
  clientApprovedAt     DateTime?
  clientApprovalSource String?
  approvalNotes        String?
  clientPortalUserId   String?
  clientCompletedAt    DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  category             TaskCategory?    @relation(fields: [categoryId], references: [id])
  client               Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salesHandoffs        SalesHandoff[]
  assignees            TaskAssignee[]
  attachments          TaskAttachment[]
  comments             TaskComment[]
  timeLogs             TaskTimeLog[]

  @@index([clientId, categoryId, status, boardOrder])
  @@index([clientPortalUserId, status])
}

model TaskCategory {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  color       String?
  icon        String?
  sortOrder   Int                  @default(0)
  isArchived  Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  actionItems ActionItem[]
  clientLinks ClientTaskCategory[]
}

model ClientTaskCategory {
  id         String       @id @default(cuid())
  clientId   String
  categoryId String
  sortOrder  Int          @default(0)
  isEnabled  Boolean      @default(true)
  createdAt  DateTime     @default(now())
  category   TaskCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, categoryId])
  @@index([clientId, sortOrder])
}

model TaskAssignee {
  id           String     @id @default(cuid())
  actionItemId String
  userId       String
  assignedAt   DateTime   @default(now())
  assignedBy   String?
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([actionItemId, userId])
  @@index([userId])
}

model TaskComment {
  id           String           @id @default(cuid())
  actionItemId String
  userId       String
  body         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  attachments  TaskAttachment[]
  actionItem   ActionItem       @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actionItemId, createdAt])
}

model TaskTimeLog {
  id           String     @id @default(cuid())
  actionItemId String
  userId       String
  startedAt    DateTime   @default(now())
  endedAt      DateTime?
  durationMs   Int?
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  actionItem   ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actionItemId, startedAt])
  @@index([userId, endedAt])
}

model TaskAttachment {
  id           String       @id @default(cuid())
  actionItemId String
  commentId    String?
  uploadedById String
  blobUrl      String
  fileName     String
  contentType  String
  sizeBytes    Int
  createdAt    DateTime     @default(now())
  actionItem   ActionItem   @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  comment      TaskComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([actionItemId, createdAt])
  @@index([commentId])
}

model ClientFile {
  id           String   @id @default(cuid())
  clientId     String
  uploadedById String
  blobUrl      String
  fileName     String
  contentType  String
  sizeBytes    Int
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model ClientCommunication {
  id                String    @id @default(cuid())
  clientId          String
  userId            String
  type              String
  direction         String    @default("outbound")
  subject           String
  body              String?
  status            String    @default("logged")
  sentAt            DateTime?
  externalMessageId String?   @unique
  metadata          String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ReportComment {
  id        String   @id @default(cuid())
  reportId  String
  sectionId String?
  userId    String
  content   String
  resolved  Boolean  @default(false)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model CompetitorSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  domain      String
  metrics     String
  insights    String?
  periodStart String
  periodEnd   String
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, domain, periodStart, periodEnd])
}

model MediaPlan {
  id          String      @id @default(cuid())
  clientId    String?
  title       String
  objective   String
  totalBudget Float
  duration    Int
  startDate   String?
  channels    String
  forecast    String?
  status      String      @default("draft")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  grandPlans  GrandPlan[]
  client      Client?     @relation(fields: [clientId], references: [id])
}

model ClientPortalUser {
  id          String    @id @default(cuid())
  clientId    String
  email       String    @unique
  name        String?
  magicToken  String?   @unique
  tokenExpiry DateTime?
  lastLoginAt DateTime?
  permissions String    @default("[]")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model DetectedAnomaly {
  id            String    @id @default(cuid())
  clientId      String
  platform      String
  metric        String
  severity      String
  direction     String
  changePercent Float
  detail        String
  rootCauseText String?
  actionsTaken  String?
  periodStart   String
  periodEnd     String
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, platform, metric])
}

model ClickFraudEvent {
  id           String   @id @default(cuid())
  clientId     String
  sessionId    String
  userAgent    String?
  ipHash       String?
  referer      String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  isSuspicious Boolean  @default(false)
  reason       String?
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId, isSuspicious])
}

model ContentStrategy {
  id                String      @id @default(cuid())
  clientId          String?
  title             String
  period            String
  createdBy         String?
  status            String      @default("live")
  generationMs      Int?
  generationStatus  String      @default("complete")
  generationError   String?
  spreadsheetData   String
  generatedHtml     String
  shareToken        String?     @unique
  sharePassword     String?
  portalPublishedAt DateTime?
  portalPublishedBy String?
  viewCount         Int         @default(0)
  lastViewedAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  client            Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  grandPlans        GrandPlan[]

  @@index([clientId, createdAt])
}

model UserActivityLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  userName     String?
  action       String
  resourceType String?
  resourceId   String?
  clientId     String?
  clientName   String?
  description  String
  metadata     String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@index([action, createdAt])
}

model SalesHandoff {
  id                        String              @id @default(cuid())
  prospectName              String
  website                   String
  targetAudienceSummary     String
  secondCallAt              DateTime
  interestedServicesJson    String              @default("[]")
  budgetRange               String
  otherInformation          String?
  urgentOverride            Boolean             @default(false)
  urgentReason              String?
  hoursUntilCall            Float?
  noticeStatus              String?
  status                    String              @default("submitted")
  clickupTaskId             String?             @unique
  clickupTaskUrl            String?
  clickupListId             String?
  clickupSyncStatus         String              @default("not_synced")
  clickupLastSyncedAt       DateTime?
  policyEnforce48HourNotice Boolean             @default(true)
  policyAllowUrgentOverride Boolean             @default(true)
  notes                     String?
  sourceIdempotencyKey      String?             @unique
  createdByUserId           String?
  ownerUserId               String?
  linkedClientId            String?
  linkedProposalId          String?
  linkedGrandPlanId         String?
  linkedActionItemId        String?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  createdBy                 User?               @relation("SalesHandoffCreatedBy", fields: [createdByUserId], references: [id])
  actionItem                ActionItem?         @relation(fields: [linkedActionItemId], references: [id])
  client                    Client?             @relation(fields: [linkedClientId], references: [id])
  grandPlan                 GrandPlan?          @relation(fields: [linkedGrandPlanId], references: [id])
  proposal                  Proposal?           @relation(fields: [linkedProposalId], references: [id])
  owner                     User?               @relation("SalesHandoffOwner", fields: [ownerUserId], references: [id])
  events                    SalesHandoffEvent[]

  @@index([status, createdAt])
  @@index([secondCallAt])
  @@index([createdByUserId, createdAt])
  @@index([ownerUserId, status])
  @@index([linkedClientId, createdAt])
  @@index([linkedProposalId])
  @@index([linkedGrandPlanId])
  @@index([linkedActionItemId])
}

model SalesHandoffEvent {
  id           String       @id @default(cuid())
  handoffId    String
  eventType    String
  title        String
  description  String?
  metadataJson String?
  actorUserId  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  actor        User?        @relation("SalesHandoffEventActor", fields: [actorUserId], references: [id])
  handoff      SalesHandoff @relation(fields: [handoffId], references: [id], onDelete: Cascade)

