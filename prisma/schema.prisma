// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Client {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  website             String?
  logoUrl             String?
  ga4PropertyId         String?
  ga4PropertyName       String?
  semrushDomain         String?
  metaAccountId         String?
  metaAccessToken       String?
  gaCredentials         String?
  googleAdsCustomerId   String?
  googleAdsAccountName  String?
  searchConsoleSiteUrl  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  reports             Report[]
  snapshots           MetricSnapshot[]
}

model Report {
  id          String          @id @default(cuid())
  clientId    String
  title       String
  period      String
  status      String          @default("draft")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  client      Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sections    ReportSection[]
  screenshots Screenshot[]
}

model ReportSection {
  id          String   @id @default(cuid())
  reportId    String
  sectionType String
  title       String
  commentary  String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id        String   @id @default(cuid())
  reportId  String
  filename  String
  url       String
  caption   String?
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model GoogleConnection {
  id           String   @id @default(cuid())
  label        String
  email        String
  refreshToken String
  createdAt    DateTime @default(now())
}

// Stores periodic metric snapshots for each client/section to enable
// historical trending, anomaly detection over multiple periods, and
// a lightweight change-log experience.
model MetricSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  sectionType String   // "googleads" | "meta" | "ga4" | "searchconsole" | "seo"
  periodStart String   // ISO date e.g. "2025-03-01"
  periodEnd   String   // ISO date e.g. "2025-03-31"
  metrics     String   // JSON blob of key→number metrics
  campaignData String? // JSON blob of per-campaign metrics array
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sectionType, periodStart, periodEnd])
}
