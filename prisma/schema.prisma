// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String   // JSON array of permission keys
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  password            String
  role                String    @default("user")
  mustChangePassword  Boolean   @default(false)
  roleId              String?
  userRole            Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  notificationPrefs   String?   // JSON: { email: boolean, slack: boolean, slackWebhook?: string, digestFrequency: "immediate"|"daily"|"weekly", quietHoursStart?: string, quietHoursEnd?: string, enabledTypes: string[] }
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  notifications       Notification[]
  conversations       ClientConversation[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Client {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  website               String?
  logoUrl               String?
  ga4PropertyId         String?
  ga4PropertyName       String?
  semrushDomain         String?
  semrushProjectId      Int?
  metaAccountId         String?
  metaAccountName       String?
  metaAccessToken       String?
  gaCredentials         String?
  googleAdsCustomerId   String?
  googleAdsAccountName  String?
  searchConsoleSiteUrl  String?
  aiReportInstructions  String?
  woocommerceUrl        String?
  woocommerceKey        String?
  woocommerceSecret     String?
  shopifyStoreDomain    String?
  shopifyAccessToken    String?
  contractedHours       String?   // JSON: Array<{service: string, hoursPerMonth: number}>
  tiktokAdvertiserId    String?
  tiktokAccessToken     String?
  microsoftAdsAccountId String?
  microsoftAdsAccountName String?
  cwvUrl                String?   // URL for Core Web Vitals tracking
  reportSchedule        String?   // JSON: { frequency: "monthly"|"weekly", dayOfMonth?: number, dayOfWeek?: number, autoApprove: boolean, templateId?: string }
  notifyEmail           String?   // Override email for report delivery
  linkedinAccountId     String?
  linkedinAccountName   String?
  linkedinAccessToken   String?
  klaviyoApiKey         String?
  klaviyoAccountName    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  reports               Report[]
  snapshots             MetricSnapshot[]
  conversations         ClientConversation[]
  notifications         Notification[]
  goals                 ClientGoal[]
  strategyDocuments     StrategyDocument[]
  budgetRecommendations BudgetRecommendation[]
}

model ClientGoal {
  id           String   @id @default(cuid())
  clientId     String
  title        String
  description  String?
  metric       String
  channel      String?
  targetValue  Float
  currentValue Float?
  unit         String?
  targetDate   String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model StrategyDocument {
  id         String   @id @default(cuid())
  clientId   String
  title      String
  period     String
  content    String
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BudgetRecommendation {
  id              String   @id @default(cuid())
  clientId        String
  periodStart     String
  periodEnd       String
  recommendations String
  summary         String?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Report {
  id               String          @id @default(cuid())
  clientId         String
  title            String
  period           String
  status           String          @default("draft")
  shareToken       String?         @unique
  customStartDate  String?
  customEndDate    String?
  compareStartDate String?
  compareEndDate   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sections         ReportSection[]
  screenshots      Screenshot[]
}

model ReportSection {
  id          String   @id @default(cuid())
  reportId    String
  sectionType String
  title       String
  commentary  String?
  contentText String?
  orderIndex  Int      @default(0)
  enabled     Boolean  @default(true)
  cardConfig  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id        String   @id @default(cuid())
  reportId  String
  sectionId String?
  filename  String
  url       String
  caption   String?
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  sections    String   // JSON: SectionConfig[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoogleConnection {
  id           String   @id @default(cuid())
  label        String
  email        String
  refreshToken String
  createdAt    DateTime @default(now())
}

// Stores periodic metric snapshots for each client/section to enable
// historical trending, anomaly detection over multiple periods, and
// a lightweight change-log experience.
model MetricSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  sectionType String   // "googleads" | "meta" | "ga4" | "searchconsole" | "seo"
  periodStart String   // ISO date e.g. "2025-03-01"
  periodEnd   String   // ISO date e.g. "2025-03-31"
  metrics     String   // JSON blob of key→number metrics
  campaignData String? // JSON blob of per-campaign metrics array
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sectionType, periodStart, periodEnd])
}

model KeywordPlannerResearch {
  id              String   @id @default(cuid())
  userId          String
  title           String
  website         String
  brief           String
  location        String   @default("2826")
  adGroups        String   // JSON: AdGroup[]
  selectedKws     String   // JSON: string[]
  ideas           String   // JSON: KeywordIdea[]
  maxCpc          String   @default("")
  monthlyBudget   String   @default("")
  conversionRate  String   @default("3")
  websiteContext   String?  // Crawled website content for AI context
  proposedServices String   @default("[]") // JSON: string[] — pre-agreed service names
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  proposals        Proposal[]
}

model Proposal {
  id              String                  @id @default(cuid())
  userId          String
  clientName      String
  website         String                  @default("")
  title           String
  html            String                  // Full generated HTML (legacy/download)
  servicesJson    String                  @default("[]") // JSON: Service[]
  timelineJson    String                  @default("[]") // JSON: TimelinePhase[]
  proposalDataJson String?               // JSON: structured proposal data for interactive viewer
  shareToken      String?                 @unique // null = not shared
  viewCount       Int                     @default(0)
  lastViewedAt    DateTime?
  researchId      String?
  research        KeywordPlannerResearch? @relation(fields: [researchId], references: [id], onDelete: SetNull)
  enquiries       ProposalEnquiry[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model ProposalEnquiry {
  id         String   @id @default(cuid())
  proposalId String
  name       String
  email      String
  phone      String?
  message    String
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model LlmTemplate {
  id              String   @id @default(cuid())
  name            String
  sector          String
  description     String?
  templateText    String   // The structure/format the AI follows to generate the llm.txt
  promptGuidance  String?  // Strategic/prioritisation instructions the AI should follow when filling this template
  isBuiltIn       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Notification system: delivers anomaly alerts, report events, and key platform events
model Notification {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  type        String   // "anomaly" | "report_ready" | "report_sent" | "report_opened" | "proposal_viewed" | "integration_error" | "goal_at_risk" | "snapshot_complete"
  severity    String?  // "high" | "medium" | "low"
  title       String
  body        String
  metadata    String?  // JSON: extra context (anomaly details, report id, etc.)
  channel     String   @default("in_app") // "in_app" | "email" | "slack"
  status      String   @default("unread") // "unread" | "read" | "dismissed"
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Conversational AI: stores chat messages per client for the "Ask the Data" feature
model ClientConversation {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  role      String   // "user" | "assistant"
  content   String
  metadata  String?  // JSON: suggested prompts, context summary, etc.
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
