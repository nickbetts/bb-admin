// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions String   // JSON array of permission keys
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  password            String
  role                String    @default("user")
  mustChangePassword  Boolean   @default(false)
  roleId              String?
  userRole            Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  notificationPrefs   String?   // JSON: { email: boolean, slack: boolean, slackWebhook?: string, digestFrequency: "immediate"|"daily"|"weekly", quietHoursStart?: string, quietHoursEnd?: string, enabledTypes: string[] }
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  sessions            Session[]
  notifications       Notification[]
  conversations       ClientConversation[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Client {
  id                    String    @id @default(cuid())
  name                  String
  slug                  String    @unique
  website               String?
  logoUrl               String?
  ga4PropertyId         String?
  ga4PropertyName       String?
  semrushDomain         String?
  semrushProjectId      Int?
  semrushCampaignIds    String?   // JSON: string[] — campaign IDs for Position Tracking (format: "{projectId}_{campaignNum}")
  metaAccountId         String?
  metaAccountName       String?
  metaAccessToken       String?
  gaCredentials         String?
  googleAdsCustomerId   String?
  googleAdsAccountName  String?
  searchConsoleSiteUrl  String?
  aiReportInstructions  String?
  woocommerceUrl        String?
  woocommerceKey        String?
  woocommerceSecret     String?
  shopifyStoreDomain    String?
  shopifyAccessToken    String?
  contractedHours       String?   // JSON: Array<{service: string, hoursPerMonth: number}>
  tiktokAdvertiserId    String?
  tiktokAccessToken     String?
  microsoftAdsAccountId String?
  microsoftAdsAccountName String?
  cwvUrl                String?   // URL for Core Web Vitals tracking
  reportSchedule        String?   // JSON: { frequency: "monthly"|"weekly", dayOfMonth?: number, dayOfWeek?: number, autoApprove: boolean, templateId?: string }
  notifyEmail           String?   // Override email for report delivery
  linkedinAccountId     String?
  linkedinAccountName   String?
  linkedinAccessToken   String?
  klaviyoApiKey         String?
  klaviyoAccountName    String?
  // Phase 3: New integrations
  hubspotPortalId       String?   // HubSpot portal ID
  hubspotAccessToken    String?   // HubSpot private app token
  youtubeChannelId      String?   // YouTube channel ID
  youtubeChannelName    String?   // YouTube channel display name
  callrailAccountId     String?   // CallRail account ID
  callrailApiKey        String?   // CallRail API key
  // Phase 3: Competitor intelligence
  competitorDomains     String?   // JSON: string[] — domains to monitor
  // Click fraud protection snippet token
  clickFraudToken       String?   @unique  // Unique token for website protection snippet
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  reports               Report[]
  snapshots             MetricSnapshot[]
  conversations         ClientConversation[]
  notifications         Notification[]
  goals                 ClientGoal[]
  strategyDocuments     StrategyDocument[]
  budgetRecommendations BudgetRecommendation[]
  actions               ActionItem[]
  communications        ClientCommunication[]
  portalUsers           ClientPortalUser[]
  competitorSnapshots   CompetitorSnapshot[]
  mediaPlans            MediaPlan[]
  detectedAnomalies     DetectedAnomaly[]
  clickFraudEvents      ClickFraudEvent[]
  contentStrategies     ContentStrategy[]
}

model ClientGoal {
  id           String   @id @default(cuid())
  clientId     String
  title        String
  description  String?
  metric       String
  channel      String?
  targetValue  Float
  currentValue Float?
  unit         String?
  targetDate   String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model StrategyDocument {
  id         String   @id @default(cuid())
  clientId   String
  title      String
  period     String
  content    String
  type       String   @default("strategy") // "strategy" | "briefing"
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BudgetRecommendation {
  id              String   @id @default(cuid())
  clientId        String
  periodStart     String
  periodEnd       String
  recommendations String
  summary         String?
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Report {
  id               String          @id @default(cuid())
  clientId         String
  title            String
  period           String
  status           String          @default("draft")
  shareToken       String?         @unique
  customStartDate  String?
  customEndDate    String?
  compareStartDate String?
  compareEndDate   String?
  // AI-generated narrative (persisted so it shows in PDF export)
  narrativeData    String?         // JSON: { executiveSummary, keyThemes, crossSectionStories, goalProgressNarrative }
  // Phase 3: Collaboration & approval
  approvalStatus   String?         // "pending" | "approved" | "changes_requested"
  approvalNotes    String?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sections         ReportSection[]
  screenshots      Screenshot[]
  comments         ReportComment[]
}

model ReportSection {
  id          String   @id @default(cuid())
  reportId    String
  sectionType String
  title       String
  commentary  String?
  contentText String?
  orderIndex  Int      @default(0)
  enabled     Boolean  @default(true)
  cardConfig  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  report      Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model Screenshot {
  id        String   @id @default(cuid())
  reportId  String
  sectionId String?
  filename  String
  url       String
  caption   String?
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  sections    String   // JSON: SectionConfig[]
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GoogleConnection {
  id           String   @id @default(cuid())
  label        String
  email        String
  refreshToken String
  createdAt    DateTime @default(now())
}

// Stores periodic metric snapshots for each client/section to enable
// historical trending, anomaly detection over multiple periods, and
// a lightweight change-log experience.
model MetricSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  sectionType String   // "googleads" | "meta" | "ga4" | "searchconsole" | "seo"
  periodStart String   // ISO date e.g. "2025-03-01"
  periodEnd   String   // ISO date e.g. "2025-03-31"
  metrics     String   // JSON blob of key→number metrics
  campaignData String? // JSON blob of per-campaign metrics array
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, sectionType, periodStart, periodEnd])
}

// Server-side runtime log — captures console.error/warn from API routes for in-platform debugging
model ServerLog {
  id        String   @id @default(cuid())
  level     String   // "error" | "warn"
  message   String
  source    String?  // route path or module context extracted from stack
  details   String?  // JSON string of extra args / stack trace
  createdAt DateTime @default(now())

  @@index([level, createdAt])
}

// Audit log for each cron/manual snapshot run
model CronLog {
  id               String    @id @default(cuid())
  jobName          String    // "snapshots" | "reports"
  triggeredBy      String    @default("cron")  // "cron" | "manual"
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  status           String    @default("running")  // "running" | "success" | "error"
  clientsTotal     Int       @default(0)
  snapshotsNew     Int       @default(0)
  snapshotsSkipped Int       @default(0)
  errors           Int       @default(0)
  details          String?   // JSON: per-client results array
}

// Short-lived cache for external API responses (SEMrush, GA4, etc.)
// to avoid burning credits / hitting rate limits on every dashboard load.
model ApiCache {
  key       String   @id   // e.g. "semrush:overview:example.com:uk"
  data      String        // JSON response blob
  fetchedAt DateTime @default(now())
  expiresAt DateTime
}

model KeywordPlannerResearch {
  id              String   @id @default(cuid())
  userId          String
  title           String
  website         String
  brief           String
  location        String   @default("2826")
  adGroups        String   // JSON: AdGroup[]
  selectedKws     String   // JSON: string[]
  ideas           String   // JSON: KeywordIdea[]
  maxCpc          String   @default("")
  monthlyBudget   String   @default("")
  conversionRate  String   @default("3")
  websiteContext   String?  // Crawled website content for AI context
  proposedServices String   @default("[]") // JSON: string[] — pre-agreed service names
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  proposals        Proposal[]
}

model Proposal {
  id              String                  @id @default(cuid())
  userId          String
  clientName      String
  website         String                  @default("")
  title           String
  html            String                  // Full generated HTML (legacy/download)
  servicesJson    String                  @default("[]") // JSON: Service[]
  timelineJson    String                  @default("[]") // JSON: TimelinePhase[]
  proposalDataJson String?               // JSON: structured proposal data for interactive viewer
  shareToken      String?                 @unique // null = not shared
  viewCount       Int                     @default(0)
  lastViewedAt    DateTime?
  researchId      String?
  // Phase 3: Pipeline CRM fields
  pipelineStage   String                  @default("prospect") // prospect|sent|viewed|negotiating|won|lost
  pipelineNotes   String?
  expectedValue   Float?
  closeDate       String?
  lostReason      String?
  research        KeywordPlannerResearch? @relation(fields: [researchId], references: [id], onDelete: SetNull)
  enquiries       ProposalEnquiry[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
}

model ProposalEnquiry {
  id         String   @id @default(cuid())
  proposalId String
  name       String
  email      String
  phone      String?
  message    String
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model LlmTemplate {
  id              String   @id @default(cuid())
  name            String
  sector          String
  description     String?
  templateText    String   // The structure/format the AI follows to generate the llm.txt
  promptGuidance  String?  // Strategic/prioritisation instructions the AI should follow when filling this template
  isBuiltIn       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Notification system: delivers anomaly alerts, report events, and key platform events
model Notification {
  id          String   @id @default(cuid())
  userId      String
  clientId    String?
  type        String   // "anomaly" | "report_ready" | "report_sent" | "report_opened" | "proposal_viewed" | "integration_error" | "goal_at_risk" | "snapshot_complete"
  severity    String?  // "high" | "medium" | "low"
  title       String
  body        String
  metadata    String?  // JSON: extra context (anomaly details, report id, etc.)
  channel     String   @default("in_app") // "in_app" | "email" | "slack"
  status      String   @default("unread") // "unread" | "read" | "dismissed"
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Conversational AI: stores chat messages per client for the "Ask the Data" feature
model ClientConversation {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  role      String   // "user" | "assistant"
  content   String
  metadata  String?  // JSON: suggested prompts, context summary, etc.
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 3: Internal Action Tracking — AI recommendations → assigned actions → outcomes
model ActionItem {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  description String?
  status      String    @default("open")    // open|in_progress|completed|cancelled
  priority    String    @default("medium")  // low|medium|high|urgent
  assignedTo  String?                       // User ID
  dueDate     String?
  completedAt DateTime?
  outcome     String?                       // Notes / measured outcome after completion
  sourceType  String?                       // "ai_recommendation" | "manual"
  sourceRef   String?                       // Reference to source (e.g., anomaly id)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Phase 3: Client Communication Hub — centralised communication log
model ClientCommunication {
  id          String    @id @default(cuid())
  clientId    String
  userId      String    // Agency user who logged/sent the communication
  type        String    // "email" | "call" | "meeting" | "note" | "report_share" | "proposal_share"
  direction   String    @default("outbound")  // "inbound" | "outbound"
  subject     String
  body        String?
  status      String    @default("logged")    // "draft" | "sent" | "logged"
  sentAt      DateTime?
  metadata    String?   // JSON: { reportId?, proposalId?, duration?, participants?: string[] }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Phase 3: Report Collaboration — comments on report sections
model ReportComment {
  id         String   @id @default(cuid())
  reportId   String
  sectionId  String?
  userId     String   // Author
  content    String
  resolved   Boolean  @default(false)
  parentId   String?  // For threaded replies
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

// Phase 3: Competitor Intelligence — ongoing competitive monitoring snapshots
model CompetitorSnapshot {
  id          String   @id @default(cuid())
  clientId    String
  domain      String
  metrics     String   // JSON: { organicTraffic?, organicKeywords?, backlinks?, paidKeywords?, etc. }
  insights    String?  // AI-generated competitive summary
  periodStart String
  periodEnd   String
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, domain, periodStart, periodEnd])
}

// Phase 3: Media Plan Builder — paid media planning with forecast outputs
model MediaPlan {
  id          String   @id @default(cuid())
  clientId    String?
  title       String
  objective   String   // "brand_awareness" | "lead_gen" | "ecommerce" | "traffic"
  totalBudget Float
  duration    Int      // Duration in days
  startDate   String?
  channels    String   // JSON: ChannelAllocation[]
  forecast    String?  // JSON: AI-generated forecast output
  status      String   @default("draft")  // draft|active|completed|archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

// Phase 3: Client Portal — self-serve client-facing dashboard access
model ClientPortalUser {
  id          String    @id @default(cuid())
  clientId    String
  email       String    @unique
  name        String?
  magicToken  String?   @unique  // Single-use login token
  tokenExpiry DateTime?
  lastLoginAt DateTime?
  permissions String    @default("[]")  // JSON: ["reports","goals","communications"]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Phase 3: Anomaly Memory — stores detected anomalies so root-cause can reference history
model DetectedAnomaly {
  id             String   @id @default(cuid())
  clientId       String
  platform       String   // "googleads" | "meta" | "ga4" | "searchconsole" | "seo" etc.
  metric         String   // The metric that triggered the anomaly
  severity       String   // "high" | "medium" | "low"
  direction      String   // "up" | "down"
  changePercent  Float
  detail         String   // Human-readable description
  rootCauseText  String?  // AI-generated root cause (short, 2-3 sentences)
  actionsTaken   String?  // JSON: string[] — actions taken in response
  periodStart    String   // ISO date
  periodEnd      String   // ISO date
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, platform, metric])
}

// Click fraud protection — events captured by the website snippet
model ClickFraudEvent {
  id           String   @id @default(cuid())
  clientId     String
  sessionId    String   // Random session ID generated by the snippet
  userAgent    String?
  ipHash       String?  // SHA-256 of IP address (privacy-safe)
  referer      String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  isSuspicious Boolean  @default(false)
  reason       String?  // "bot_ua" | "headless" | "no_interaction" | "rapid_repeat"
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId, isSuspicious])
}

model ContentStrategy {
  id              String   @id @default(cuid())
  clientId        String?
  title           String
  period          String
  createdBy       String?
  spreadsheetData String   // JSON: parsed spreadsheet data
  generatedHtml   String   // Full standalone HTML output
  shareToken      String?  @unique
  sharePassword   String?  // bcrypt hash of password for share link
  viewCount       Int      @default(0)
  lastViewedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}
